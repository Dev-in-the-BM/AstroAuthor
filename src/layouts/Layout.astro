---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />

    <!-- Fancybox for image galleries (Magic Move) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
    <style is:inline>
      /* Smooth out and slow down the Fancybox 'magic move' transition */
      .fancybox__container {
        --f-animation-duration: 0.4s;
        --f-transition-duration: 0.4s;
        --f-animation-easing: ease-in-out;
      }

      /* --- Rich Link Card Redesign --- */

      /* Main container for the link card */
      .rlc-container {
        display: flex;
        border: 1px solid rgb(var(--aw-color-border));
        border-radius: 0.5rem; /* lg */
        overflow: hidden;
        text-decoration: none;
        transition: all 0.2s ease-in-out;
        margin: 1.5rem 0;
        max-height: none; /* Remove previous height limit */
      }

      .rlc-container:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1); /* shadow-md */
        border-color: rgb(var(--aw-color-primary) / 0.8);
      }

      /* Text content area */
      .rlc-info {
        padding: 1rem;
        flex-grow: 1;
        min-width: 0; /* Important for flex text truncation */
      }

      /* Card Title */
      .rlc-title {
        font-size: 1.125rem; /* text-lg */
        font-weight: 600; /* font-semibold */
        color: rgb(var(--aw-color-text-default));
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 0.25rem;
      }

      /* Card Description */
      .rlc-description {
        font-size: 0.9rem;
        color: rgb(var(--aw-color-text-muted));
        line-height: 1.4;
        /* Truncate to 2 lines for a clean look */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* URL and Favicon at the bottom */
      .rlc-url-container {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
      }

      .rlc-favicon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
      }

      .rlc-url {
        font-size: 0.8rem;
        color: rgb(var(--aw-color-text-muted));
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      /* Image container */
      .rlc-image-container {
        flex-basis: 220px;
        flex-shrink: 0;
        max-height: none;
        order: 1; /* Puts image on the right */
        background-color: rgb(var(--aw-color-bg-subtle));
      }

      .rlc-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* Mobile responsive layout */
      @media (max-width: 640px) {
        .rlc-container {
          flex-direction: column;
        }
        .rlc-image-container {
          order: -1; /* Image on top on mobile */
          flex-basis: 180px;
        }
      }
    </style>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        // Re-bind Fancybox events when moving between pages
        if (typeof Fancybox !== 'undefined') {
          Fancybox.unbind('[data-fancybox]');
          Fancybox.bind('[data-fancybox]', {
            Images: { zoom: true }
          });
        }

        setupSmoothDetails();
        cleanupLinkCards();
      });

      // Close lightbox before navigating to a new page
      document.addEventListener('astro:before-preparation', () => {
        if (typeof Fancybox !== 'undefined') Fancybox.close();
      });

      // Clean up link preview cards for better display
      function cleanupLinkCards() {
        document.querySelectorAll('.rlc-container').forEach(card => {
          const href = card.getAttribute('href');
          if (!href) return;

          // --- URL display logic: Show hostname instead of full URL ---
          const urlDisplay = card.querySelector('.rlc-url');
          if (urlDisplay) {
            try {
              const url = new URL(href);
              // Remove 'www.' for a cleaner look and show only the hostname
              urlDisplay.textContent = url.hostname.replace(/^www\./, '');
            } catch (e) {
              /* Fallback for invalid URLs, do nothing */
            }
          }

          // --- GitHub specific cleanup ---
          if (href.includes('github.com')) {
            const title = card.querySelector('.rlc-title');
            const desc = card.querySelector('.rlc-description');

            if (desc?.textContent) {
              desc.textContent = desc.textContent.replace(/\s*Contribute to [^\s]+ development by creating an account on GitHub\.?/i, '').trim();
            }
            if (title?.textContent) {
              const titleMatch = title.textContent.match(/GitHub - ([^:]+)/);
              if (titleMatch?.[1]) {
                title.textContent = titleMatch[1].trim();
              }
            }
          }
        });
      }

      // Smooth animation for <details> tags
      function setupSmoothDetails() {
        document.querySelectorAll('details').forEach(details => {
          const summary = details.querySelector('summary');
          if (!summary || details.dataset.smoothInit) return;
          details.dataset.smoothInit = "true";

          summary.addEventListener('click', (e) => {
            e.preventDefault();
            
            // Prevent clicking while animation is already running
            if (details.dataset.isAnimating) return;
            details.dataset.isAnimating = "true";

            const isOpen = details.hasAttribute('open');

            if (isOpen) {
              // Calculate heights for closing
              const startHeight = details.offsetHeight;
              details.removeAttribute('open');
              const endHeight = details.offsetHeight;
              details.setAttribute('open', '');

              details.style.height = startHeight + 'px';
              details.style.overflow = 'hidden';
              details.offsetHeight; // force browser reflow

              details.style.transition = 'height 0.3s ease-in-out';
              details.style.height = endHeight + 'px';

              setTimeout(() => {
                details.removeAttribute('open');
                details.style.height = '';
                details.style.transition = '';
                details.style.overflow = '';
                delete details.dataset.isAnimating;
              }, 300);
            } else {
              // Calculate heights for opening
              const startHeight = details.offsetHeight;
              details.setAttribute('open', '');
              const endHeight = details.offsetHeight;

              details.style.height = startHeight + 'px';
              details.style.overflow = 'hidden';
              details.offsetHeight; // force browser reflow

              details.style.transition = 'height 0.3s ease-in-out';
              details.style.height = endHeight + 'px';

              setTimeout(() => {
                details.style.height = '';
                details.style.transition = '';
                details.style.overflow = '';
                delete details.dataset.isAnimating;
              }, 300);
            }
          });
        });
      }
    </script>
  </body>
</html>
